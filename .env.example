# Database
DATABASE_URL="postgresql://user:password@localhost:5432/3d_suite"

# WeTransfer API
WETRANSFER_API_KEY="your_wetransfer_api_key"
WETRANSFER_API_URL="https://api.wetransfer.com"

# Temporary Email Service (e.g., TempMail, Guerrilla Mail)
TEMP_EMAIL_API_KEY="your_temp_email_api_key"
TEMP_EMAIL_PROVIDER="tempmail" # or guerrillamail

# Redis/Bull Queue
REDIS_URL="redis://localhost:6379"

# Email Service (for sending campaign links)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM="noreply@3dsuite.com"

# Proxy Configuration (optional)
PROXY_ENABLED="false"
PROXY_LIST="proxy1.com:8080,proxy2.com:8080"

# General
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"
